# =============================================================================
# Borac Sport — Variables de entorno (EJEMPLO)
# Copia este archivo a .env.local y completá con credenciales reales.
# NUNCA commitees .env.local ni expongas variables sin NEXT_PUBLIC_ al cliente.
# =============================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_REPLACE_WITH_YOUR_KEY"
# Service role key — SOLO server-side. Bypassa RLS.
# Se usa para subir comprobantes de pago a boracsport_orders.
SUPABASE_SERVICE_ROLE_KEY="REPLACE_WITH_YOUR_SERVICE_ROLE_KEY"

# Mercado Pago Uruguay (UYU)
# El servidor falla de forma segura si falta el access token.
MERCADOPAGO_ACCESS_TOKEN="APP_USR-REPLACE_WITH_YOUR_TOKEN"
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="APP_USR-REPLACE_WITH_YOUR_PUBLIC_KEY"

# URL pública usada para retornos y allowlist del bridge
# En Vercel: setear NEXT_PUBLIC_APP_URL a la URL canónica (ej: https://boracsport.com.uy).
# NEXT_PUBLIC_VERCEL_URL se inyecta automáticamente en deployments de Vercel.
# Prioridad: NEXT_PUBLIC_APP_URL > NEXT_PUBLIC_SITE_URL > NEXT_PUBLIC_VERCEL_URL > http://localhost:3000
NEXT_PUBLIC_APP_URL="https://boracsport.com.uy"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Webhook de Mercado Pago: debe apuntar a
# https://TU-DOMINIO/api/checkout/mercadopago/webhook
MERCADOPAGO_WEBHOOK_SECRET="REPLACE_WITH_WEBHOOK_SECRET_IF_ENABLED"

# Opcional: limita pedidos invitados por IP en el reverse proxy/WAF.
# No es un secreto y no es leído por el cliente.
ORDER_RATE_LIMIT_PER_MINUTE="10"

# Email transaccional vía Resend (https://resend.com).
# Si RESEND_API_KEY no está seteada, los pedidos se siguen creando
# pero NO se envía mail — el servidor loguea un warning.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Borac Sport <no-reply@boracsport.com.uy>"
RESEND_ADMIN_EMAIL="ventas@boracsport.com.uy"
